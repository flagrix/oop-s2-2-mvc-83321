@model FoodSafetyTracker.Models.Inspection
@{
    ViewData["Title"] = "Edit Inspection";
}

<h1 class="mb-4">✏️ Edit Inspection</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="PremisesId" class="form-label">Premises</label>
                <select asp-for="PremisesId" class="form-select" asp-items="ViewBag.Premises"></select>
            </div>
            <div class="mb-3">
                <label asp-for="InspectionDate" class="form-label"></label>
                <input asp-for="InspectionDate" type="date" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Score" class="form-label">Score (0–100)</label>
                <input asp-for="Score" type="number" min="0" max="100" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Outcome" class="form-label"></label>
                <select asp-for="Outcome" asp-items="Html.GetEnumSelectList<FoodSafetyTracker.Models.OutcomeResult>()" class="form-select"></select>
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
