@model IEnumerable<FoodSafetyTracker.Models.FollowUp>
@{
    ViewData["Title"] = "Follow-Ups";
}

<h1 class="mb-4">📋 Follow-Ups</h1>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Premises</th>
            <th>Inspection Date</th>
            <th>Due Date</th>
            <th>Status</th>
            <th>Closed Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var f in Model)
        {
            var isOverdue = f.DueDate < DateTime.Now && f.Status == FoodSafetyTracker.Models.FollowUpStatus.Open;
            <tr class="@(isOverdue ? "table-danger" : "")">
                <td>@f.Inspection?.Premises?.Name</td>
                <td>@f.Inspection?.InspectionDate.ToString("dd/MM/yyyy")</td>
                <td>@f.DueDate.ToString("dd/MM/yyyy") @(isOverdue ? "⚠️ Overdue" : "")</td>
                <td>
                    <span class="badge @(f.Status == FoodSafetyTracker.Models.FollowUpStatus.Open ? "bg-warning text-dark" : "bg-success")">
                        @f.Status
                    </span>
                </td>
                <td>@(f.ClosedDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                <td>
                    @if (f.Status == FoodSafetyTracker.Models.FollowUpStatus.Open &&
                         (User.IsInRole("Admin") || User.IsInRole("Inspector")))
                    {
                        <a asp-action="Close" asp-route-id="@f.Id" class="btn btn-sm btn-success">Close</a>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@f.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
