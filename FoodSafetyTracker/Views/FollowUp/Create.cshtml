@model FoodSafetyTracker.Models.FollowUp
@{
    ViewData["Title"] = "New Follow-Up";
    var inspection = ViewBag.Inspection as FoodSafetyTracker.Models.Inspection;
}

<h1 class="mb-4">📋 New Follow-Up</h1>

@if (inspection != null)
{
    <div class="alert alert-info mb-4">
        For inspection of <strong>@inspection.Premises?.Name</strong> on @inspection.InspectionDate.ToString("dd/MM/yyyy")
        — Outcome: <strong>@inspection.Outcome</strong>
    </div>
}

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="InspectionId" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="DueDate" class="form-label"></label>
                <input asp-for="DueDate" type="date" class="form-control" />
                <span asp-validation-for="DueDate" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" asp-items="Html.GetEnumSelectList<FoodSafetyTracker.Models.FollowUpStatus>()" class="form-select"></select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Create</button>
                <a asp-controller="Inspection" asp-action="Details" asp-route-id="@Model.InspectionId" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
