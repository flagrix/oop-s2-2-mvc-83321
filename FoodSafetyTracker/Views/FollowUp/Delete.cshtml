@model FoodSafetyTracker.Models.FollowUp
@{
    ViewData["Title"] = "Delete Follow-Up";
}

<h1 class="mb-4">🗑️ Delete Follow-Up</h1>

<div class="alert alert-danger">
    Are you sure you want to delete this follow-up?
</div>

<dl class="row">
    <dt class="col-sm-3">Inspection</dt>
    <dd class="col-sm-9">#@Model.InspectionId</dd>
    <dt class="col-sm-3">Due Date</dt>
    <dd class="col-sm-9">@Model.DueDate.ToString("dd/MM/yyyy")</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
