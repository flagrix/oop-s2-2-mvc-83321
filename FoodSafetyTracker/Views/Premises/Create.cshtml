@model FoodSafetyTracker.Models.Premises
@{
    ViewData["Title"] = "New Premises";
}

<h1 class="mb-4">🏢 New Premises</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Address" class="form-label"></label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Town" class="form-label"></label>
                <input asp-for="Town" class="form-control" />
                <span asp-validation-for="Town" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="RiskRating" class="form-label"></label>
                <select asp-for="RiskRating" asp-items="Html.GetEnumSelectList<FoodSafetyTracker.Models.RiskRating>()" class="form-select"></select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Create</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
