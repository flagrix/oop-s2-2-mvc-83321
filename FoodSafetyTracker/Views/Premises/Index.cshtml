@model IEnumerable<FoodSafetyTracker.Models.Premises>
@{
    ViewData["Title"] = "Premises";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>🏢 Premises</h1>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-success">+ New Premises</a>
    }
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Address</th>
                <th>Town</th>
                <th>Risk Rating</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Name</td>
                    <td>@p.Address</td>
                    <td>@p.Town</td>
                    <td>
                        <span class="badge @(p.RiskRating == FoodSafetyTracker.Models.RiskRating.High ? "bg-danger" : p.RiskRating == FoodSafetyTracker.Models.RiskRating.Medium ? "bg-warning text-dark" : "bg-success")">
                            @p.RiskRating
                        </span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Details</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
