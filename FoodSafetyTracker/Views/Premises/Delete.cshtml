@model FoodSafetyTracker.Models.Premises
@{
    ViewData["Title"] = "Delete Premises";
}

<h1 class="mb-4">🗑️ Delete Premises</h1>

<div class="alert alert-danger">
    Are you sure you want to delete <strong>@Model.Name</strong>?
</div>

<dl class="row">
    <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Town</dt><dd class="col-sm-9">@Model.Town</dd>
    <dt class="col-sm-3">Risk Rating</dt><dd class="col-sm-9">@Model.RiskRating</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
